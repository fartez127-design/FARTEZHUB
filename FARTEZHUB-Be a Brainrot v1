local function CreateToggleButton(parentPage, text, varName)
    local btn = Instance.new("TextButton", parentPage)
    btn.Size = UDim2.new(0.9, 0, 0, 40); btn.BackgroundColor3 = Theme.SurfaceLight; btn.Text = text; btn.TextColor3 = Theme.Text; btn.Font = Enum.Font.GothamBold; btn.TextSize = 12
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    btn.MouseButton1Click:Connect(function()
        _G[varName] = not _G[varName]
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = _G[varName] and Theme.Accent or Theme.SurfaceLight, TextColor3 = _G[varName] and Color3.new(0,0,0) or Theme.Text}):Play()
    end)
    return btn
end

local function CreateToggleWithInput(parentPage, text, toggleVar, numVar, minVal, maxVal)
    local frame = Instance.new("Frame", parentPage)
    frame.Size = UDim2.new(0.9, 0, 0, 40); frame.BackgroundTransparency = 1
    
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.65, 0, 1, 0); btn.BackgroundColor3 = Theme.SurfaceLight; btn.Text = text; btn.TextColor3 = Theme.Text; btn.Font = Enum.Font.GothamBold; btn.TextSize = 11
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    btn.MouseButton1Click:Connect(function()
        _G[toggleVar] = not _G[toggleVar]
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = _G[toggleVar] and Theme.Accent or Theme.SurfaceLight, TextColor3 = _G[toggleVar] and Color3.new(0,0,0) or Theme.Text}):Play()
    end)
    
    local input = Instance.new("TextBox", frame)
    input.Size = UDim2.new(0.3, 0, 1, 0); input.Position = UDim2.new(0.7, 0, 0, 0); input.BackgroundColor3 = Theme.SurfaceLight; input.TextColor3 = Theme.Accent; input.Font = Enum.Font.GothamBold; input.TextSize = 14
    input.Text = tostring(_G[numVar])
    Instance.new("UICorner", input).CornerRadius = UDim.new(0, 8)
    
    input.FocusLost:Connect(function()
        local val = tonumber(input.Text)
        if val then val = math.clamp(val, minVal, maxVal); _G[numVar] = val; input.Text = tostring(val)
        else input.Text = tostring(_G[numVar]) end
    end)
    return frame
end

