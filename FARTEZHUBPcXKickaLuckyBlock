-- ================= [ GLOBAL x2 AUTO CLICKER (FIXED POP) ] ================= --
task.spawn(function()
    local lastX2 = 0
    while true do
        pcall(function()
            local kickUp = PlayerGui:FindFirstChild("KickUpgrades")
            if kickUp then
                for _, child in pairs(kickUp:GetChildren()) do
                    if child:IsA("GuiObject") and child.Visible and (child.Name == "Bonus" or child.Name == "Pop" or child:FindFirstChild("TextLabel")) then
                        if (tick() - lastX2) > 1.5 then
                            Net.rev_TaviMishkal:FireServer()
                            pcall(function()
                                if getconnections then
                                    for _, desc in pairs(child:GetDescendants()) do
                                        if desc:IsA("GuiButton") or desc:IsA("TextButton") or desc:IsA("ImageButton") then
                                            for _, c in pairs(getconnections(desc.MouseButton1Click)) do c:Fire() end
                                            for _, c in pairs(getconnections(desc.Activated)) do c:Fire() end
                                        end
                                    end
                                end
                            end)
                            child.Visible = false
                            lastX2 = tick()
                        end
                    end
                end
            end
        end)
        task.wait(0.5)
    end
end)

