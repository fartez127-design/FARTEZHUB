local function ForceClick(target)
    if not target or not target.Parent then return end
    
    if getconnections then
        pcall(function() for _, c in pairs(getconnections(target.MouseButton1Down)) do c:Fire() end end)
        pcall(function() for _, c in pairs(getconnections(target.MouseButton1Click)) do c:Fire() end end)
        pcall(function() for _, c in pairs(getconnections(target.Activated)) do c:Fire() end end)
    end
    if firesignal then
        pcall(function() firesignal(target.MouseButton1Down) end)
        pcall(function() firesignal(target.MouseButton1Click) end)
        pcall(function() firesignal(target.Activated) end)
    end
    
    pcall(function()
        if target:IsA("GuiButton") then target:Activate() end
    end)
    
    pcall(function()
        if target:IsA("GuiObject") and target.AbsoluteSize.X > 0 and target.Visible then
            if target.AbsolutePosition.X >= 0 and target.AbsolutePosition.X <= workspace.CurrentCamera.ViewportSize.X then
                local vim = game:GetService("VirtualInputManager")
                local guiInset = game:GetService("GuiService"):GetGuiInset()
                local clickX = target.AbsolutePosition.X + (target.AbsoluteSize.X / 2) + guiInset.X
                local clickY = target.AbsolutePosition.Y + (target.AbsoluteSize.Y / 2) + guiInset.Y
                
                vim:SendMouseButtonEvent(clickX, clickY, 0, true, game, 1)
                task.wait(0.01)
                vim:SendMouseButtonEvent(clickX, clickY, 0, false, game, 1)
            end
        end
    end)
end

