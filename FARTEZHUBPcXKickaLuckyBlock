    local l = Instance.new("TextLabel", DetailsTab)
    l.Size = UDim2.new(1, 0, 0, 25); l.BackgroundTransparency = 1
    l.Text = txt; l.TextColor3 = clr; l.Font = Enum.Font.GothamBold; l.TextSize = 12
end
