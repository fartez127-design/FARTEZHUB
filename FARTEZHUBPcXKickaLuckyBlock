local kickValues = {
    ["Perfect"] = 1, ["Excellent"] = 0.867, ["Great"] = 0.635, ["Mid"] = 0.264, ["Bad"] = 0.067
}
local currentKickMode = "Perfect"
CreateDropdown(MainTab, "Kick Power", {"Perfect", "Excellent", "Great", "Mid", "Bad"}, function(val) currentKickMode = val end)

local mutationList = {"Normal", "Gold", "Diamond", "Plasma", "Molten", "Radioactive", "Shadow", "Electrified", "Rainbow"}
local targetMutations = {}
CreateMultiDropdown(MainTab, "Mutation", mutationList, function(selected) targetMutations = selected end)

local autoKick = false

CreateToggle(MainTab, " Auto Kick (Warp Loop & Claim)", function(v)
    autoKick = v
    if autoKick then
        task.spawn(function()
            while autoKick do
                pcall(function()
                    local char = player.Character
                    if not char then return end
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local hum = char:FindFirstChild("Humanoid")
                    
                    if hrp and hum then
                        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
                        
                        ForcedTP(workspace.Areas.KickReady.CFrame + Vector3.new(0, 1.5, 0))
                        task.wait(0.2)
                        
                        Net.rev_KickEvent:FireServer(kickValues[currentKickMode] or 1)
                        task.wait(0.2) 
                        Net.rev_Transformed:FireServer()
                        
                        while PlayerGui:FindFirstChild("RandomBrainrotGui") and PlayerGui.RandomBrainrotGui.Enabled do
                            task.wait(0.1)
                        end
                        
                        local targetMonster = nil 
                        local foundTarget = false
                        local selectedCount = 0
                        for k, isSelected in pairs(targetMutations) do if isSelected then selectedCount = selectedCount + 1 end end
                        
                        for i = 1, 50 do
                            if not autoKick then break end
                            for _, obj in pairs(workspace.Debris:GetChildren()) do
                                if obj:IsA("Model") and not obj:FindFirstChild("LuckyBlock") then
                                    local root = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                                    if root and (root.Position - hrp.Position).Magnitude < 200 then
                                        targetMonster = obj 
                                        if selectedCount == 0 then foundTarget = true
                                        else
                                            for _, m in ipairs(mutationList) do
                                                if obj:FindFirstChild(m) or obj:FindFirstChild(m, true) then
                                                    if targetMutations[m] then foundTarget = true end
                                                end
                                            end
                                            if targetMutations["Normal"] then foundTarget = true end
                                        end
                                        break
                                    end
                                end
                            end
                            if targetMonster then break end
                            task.wait(0.1)
                        end
                        
                        if targetMonster then
                            if foundTarget then
                                local timer = 0
                                while timer < warpDelayValue and autoKick do
                                    task.wait(1)
                                    timer = timer + 1
                                end
                                
                                local safePos = Vector3.new(673.375, -6.903, 242.360) 
                                local safeZone = workspace.Lobby:FindFirstChild("Safe")
                                if safeZone then
                                    safePos = safeZone:IsA("BasePart") and safeZone.Position or safeZone:GetPivot().Position
                                end
                                
                                if autoKick then
                                    ForcedTP(CFrame.new(safePos + Vector3.new(0, 3, 0)))
                                    
                                    -- รอของเข้าตัว 2 วิ แล้ววนลูปกลับไปเตะใหม่
                                    task.wait(2)
                                end
                            else
                                hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
                                char:BreakJoints()
                                task.wait(3)
                            end
                        else
                            task.wait(0.5)
                        end
                    end
                end)
                task.wait(0.5)
            end
        end)
    else
        local char = player.Character
        if char and char:FindFirstChild("Humanoid") then
            char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
        end
    end
end)

