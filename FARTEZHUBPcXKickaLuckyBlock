local function ForcedTP(targetCFrame)
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.Velocity = Vector3.new(0,0,0)
        hrp.Anchored = true
        hrp.CFrame = targetCFrame
        task.wait(0.1)
        hrp.Anchored = false
    end
end

