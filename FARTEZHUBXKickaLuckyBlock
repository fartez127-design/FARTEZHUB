local autoKick = false

CreateToggle(MainTab, " Auto Kick (Warp Delay)", function(v)
    autoKick = v
    if autoKick then
        task.spawn(function()
            local vaultArea = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild("Vault")
            
            while autoKick do
                pcall(function()
                    local char = player.Character
                    if not char then return end
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    local hum = char:FindFirstChild("Humanoid")
                    
                    if hrp and hum then
                        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
                        
                        ForcedTP(workspace.Areas.KickReady.CFrame + Vector3.new(0, 1.5, 0))
                        task.wait(0.2)
                        
                        Net.rev_KickEvent:FireServer(kickValues[currentKickMode] or 1)
                        task.wait(0.2) 
                        Net.rev_Transformed:FireServer()
                        
                        while PlayerGui:FindFirstChild("RandomBrainrotGui") and PlayerGui.RandomBrainrotGui.Enabled do
                            task.wait(0.1)
                        end
                        
                        local targetMonster = nil 
                        local foundTarget = false
                        local selectedCount = 0
                        for k, isSelected in pairs(targetMutations) do if isSelected then selectedCount = selectedCount + 1 end end
                        
                        for i = 1, 50 do
                            if not autoKick then break end
                            for _, obj in pairs(workspace.Debris:GetChildren()) do
                                if obj:IsA("Model") and not obj:FindFirstChild("LuckyBlock") then
                                    local root = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                                    if root then
                                        local inVault = true
                                        if vaultArea then
                                            if (root.Position - vaultArea:GetPivot().Position).Magnitude > 250 then
                                                inVault = false
                                            end
                                        end
                                        
                                        if inVault and (root.Position - hrp.Position).Magnitude < 500 then
                                            targetMonster = obj 
                                            if selectedCount == 0 then foundTarget = true
                                            else
                                                for _, m in ipairs(mutationList) do
                                                    if obj:FindFirstChild(m) or obj:FindFirstChild(m, true) then
                                                        if targetMutations[m] then foundTarget = true end
                                                    end
                                                end
                                                if targetMutations["Normal"] then foundTarget = true end
                                            end
                                            break
