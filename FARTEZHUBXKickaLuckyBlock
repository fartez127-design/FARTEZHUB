                                        ForcedTP(targetCFrame + Vector3.new(0, 1.5, 0))
                                        task.wait(0.1)
                                        Net.rev_B_Collect:FireServer(i)
                                    end)
                                end
                            end
                        end
                    end
                end
                task.wait(1.5)
            end
        end)
    end
end)

