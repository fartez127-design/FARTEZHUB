    DropList.AutomaticCanvasSize = Enum.AutomaticSize.Y 
    Instance.new("UICorner", DropList).CornerRadius = UDim.new(0, 4)
    Instance.new("UIListLayout", DropList)

    SelectBtn.MouseButton1Click:Connect(function() DropList.Visible = not DropList.Visible end)

