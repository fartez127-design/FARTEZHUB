local function CreateToggle(parent, title, callback)
    local TogFrame = Instance.new("Frame", parent)
    TogFrame.Size = UDim2.new(1, -20, 0, 35)
    TogFrame.BackgroundColor3 = Theme.SurfaceLight
    Instance.new("UICorner", TogFrame).CornerRadius = UDim.new(0, 6)

