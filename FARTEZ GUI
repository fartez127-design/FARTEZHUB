    drop.Position = UDim2.new(math.random(), 0, -0.1, 0)
    drop.BackgroundColor3 = Theme.Accent 
    drop.BackgroundTransparency = 0.7
    drop.BorderSizePixel = 0
    drop.ZIndex = 2
    table.insert(RainDrops, {Object = drop, Speed = math.random(15, 35) / 100})
end

RunService.RenderStepped:Connect(function()
    for _, drop in pairs(RainDrops) do
        local cp = drop.Object.Position
        drop.Object.Position = UDim2.new(cp.X.Scale, 0, cp.Y.Scale + drop.Speed, 0)
        if drop.Object.Position.Y.Scale > 1.1 then
            drop.Object.Position = UDim2.new(math.random(), 0, -0.1, 0)
        end
    end
end)

