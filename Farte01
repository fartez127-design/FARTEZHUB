task.spawn(function()
    while task.wait(0.5) do
        if _G.Hitbox then
            pcall(function()
                for _, v in pairs(Players:GetPlayers()) do
                    if v ~= plr and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                        local hrp = v.Character.HumanoidRootPart
                        hrp.Size = Vector3.new(_G.HitboxSize, _G.HitboxSize, _G.HitboxSize)
                        hrp.Transparency = 0.8
                        hrp.BrickColor = BrickColor.new("Bright red")
                        hrp.Material = Enum.Material.Neon
                        hrp.CanCollide = false
                        hrp.Massless = true
                    end
                end
            end)
        end
    end
end)

task.spawn(function()
    while task.wait(0.1) do
        if (_G.AutoSteal or _G.StealEvent or _G.AutoCollect or _G.AutoCollectCoin) and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                local char = plr.Character
                local rootPos = char.HumanoidRootPart.Position

                for _, v in pairs(workspace:GetDescendants()) do
                    -- 1. STEAL BLOCKS
                    if v:IsA("ClickDetector") or v:IsA("ProximityPrompt") then
                        local model = v:FindFirstAncestorOfClass("Model") or v.Parent
                        if model and model.Name then
                            local match = false
                            
                            if _G.StealEvent then
                                for _, name in pairs(EventBlocksList) do if model.Name:find(name) then match = true break end end
                            end
                            if not match and _G.AutoSteal then
                                for name, sel in pairs(_G.SelectedBlocks) do if sel and model.Name:find(name) then match = true break end end
                            end
                            
                            if match and (rootPos - (model:GetPivot().Position)).Magnitude < _G.StealRange then
                                if v:IsA("ClickDetector") then fireclickdetector(v) else fireproximityprompt(v) end
                            end
                        end
                    end
                    
                    -- 2. COLLECT MONEY & COINS
                    if v:IsA("TouchTransmitter") or v.Name == "TouchInterest" then
                        local part = v.Parent
                        if part and part:IsA("BasePart") then
                            
                            local hasText = false
                            local isSafeMoney = false

                            for _, desc in pairs(part:GetDescendants()) do
                                if desc:IsA("TextLabel") or desc:IsA("SurfaceGui") or desc:IsA("BillboardGui") then 
                                    hasText = true
                                    if desc:IsA("TextLabel") and (desc.Text:find("%$") or desc.Text:find("%+")) then
                                        isSafeMoney = true
                                        for _, b in pairs(Blacklist) do 
                                            if desc.Text:lower():find(b, 1, true) then isSafeMoney = false break end 
                                        end
                                    end
                                end
                            end

                            if _G.AutoCollect and isSafeMoney then
                                firetouchinterest(char.HumanoidRootPart, part, 0)
                                firetouchinterest(char.HumanoidRootPart, part, 1) 
                            end

                            if _G.AutoCollectCoin and not hasText then
                                local pColor = part.Color
                                local r, g, b = pColor.R * 255, pColor.G * 255, pColor.B * 255
                                if r > 150 and b > 150 and g < 200 then
                                    firetouchinterest(char.HumanoidRootPart, part, 0)
                                    firetouchinterest(char.HumanoidRootPart, part, 1)
                                end
                            end

                        end
                    end
                end
            end)
        end
    end
end)

-- TRAIN & WALK SPEED LOOP
task.spawn(function()
    local wasWalkSpeedOn = false
    while task.wait(0.1) do
        if _G.AutoTrain and plr.Character then
            pcall(function()
                local tool = plr.Character:FindFirstChildOfClass("Tool")
                if not tool then
                    for _, t in pairs(plr.Backpack:GetChildren()) do
                        if t:IsA("Tool") then plr.Character.Humanoid:EquipTool(t); tool = t; break end
                    end
                end
                if tool then
                    tool:Activate()
                    local cam = workspace.CurrentCamera; local center = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
                    VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, true, game, 1); task.wait(0.01); VirtualInputManager:SendMouseButtonEvent(center.X, center.Y, 0, false, game, 1)
                end
            end)
        end
        
        pcall(function()
            if _G.WalkSpeedToggle and plr.Character and plr.Character:FindFirstChild("Humanoid") then
                plr.Character.Humanoid.WalkSpeed = _G.WalkSpeedValue
                wasWalkSpeedOn = true
            elseif wasWalkSpeedOn and not _G.WalkSpeedToggle and plr.Character and plr.Character:FindFirstChild("Humanoid") then
                plr.Character.Humanoid.WalkSpeed = 16 
                wasWalkSpeedOn = false
            end
        end)
    end
end)

