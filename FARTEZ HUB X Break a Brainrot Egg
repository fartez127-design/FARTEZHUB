    Btn.Size = UDim2.new(0, 80, 0, 28); Btn.BackgroundColor3 = Theme.SurfaceLight; Btn.Text = name; Btn.TextColor3 = Theme.TextDim; Btn.TextSize = 11; Btn.Font = Enum.Font.GothamBold
