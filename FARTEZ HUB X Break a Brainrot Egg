local function CreateToggleWithInput(parentPage, text, toggleVar, numVar, minVal, maxVal)
    local frame = Instance.new("Frame", parentPage)
    frame.Size = UDim2.new(0, 300, 0, 45); frame.BackgroundTransparency = 1
    
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.65, 0, 1, 0); btn.BackgroundColor3 = Theme.SurfaceLight; btn.Text = "  "..text; btn.TextColor3 = Theme.Text; btn.Font = Enum.Font.GothamBold; btn.TextSize = 11; btn.TextXAlignment = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
    
    local Status = Instance.new("Frame", btn)
    Status.Size = UDim2.new(0, 10, 0, 10); Status.Position = UDim2.new(1, -15, 0.5, -5); Status.BackgroundColor3 = Theme.TextDim
    Instance.new("UICorner", Status).CornerRadius = UDim.new(1, 0)
    
    btn.MouseButton1Click:Connect(function()
        _G[toggleVar] = not _G[toggleVar]
        local isActive = _G[toggleVar]
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = isActive and Theme.Accent or Theme.SurfaceLight, TextColor3 = isActive and Color3.new(0,0,0) or Theme.Text}):Play()
        TweenService:Create(Status, TweenInfo.new(0.2), {BackgroundColor3 = isActive and Theme.Accent or Theme.TextDim}):Play()
    end)
    
    local input = Instance.new("TextBox", frame)
    input.Size = UDim2.new(0.3, 0, 1, 0); input.Position = UDim2.new(0.7, 0, 0, 0); input.BackgroundColor3 = Theme.SurfaceLight; input.TextColor3 = Theme.Accent; input.Font = Enum.Font.GothamBold; input.TextSize = 14
    input.Text = "Platform: " .. tostring(_G[numVar])
    Instance.new("UICorner", input).CornerRadius = UDim.new(0, 8)
    
    input.FocusLost:Connect(function()
        local valStr = input.Text:match("%d+")
        local val = tonumber(valStr)
        if val then 
            val = math.clamp(val, minVal, maxVal)
            _G[numVar] = val
            input.Text = "Platform: " .. tostring(val)
        else 
            input.Text = "Platform: " .. tostring(_G[numVar]) 
        end
    end)
    return frame
end

