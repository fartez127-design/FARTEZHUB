-- 🕵️‍♂️ ฟังก์ชั่นดึงรหัส UUID ของไข่ออกมา
local function GetEggUUID(obj)
    -- เช็คชื่อ
    if #obj.Name == 36 and string.match(obj.Name, "%w+%-%w+%-%w+%-%w+%-%w+") then return obj.Name end
    -- เช็ค Attribute
    for _, attrValue in pairs(obj:GetAttributes()) do
        if type(attrValue) == "string" and #attrValue == 36 and string.match(attrValue, "%w+%-%w+%-%w+%-%w+%-%w+") then
            return attrValue
        end
    end
    -- เช็ค StringValue ข้างใน
    local val = obj:FindFirstChildWhichIsA("StringValue")
    if val and #val.Value == 36 and string.match(val.Value, "%w+%-%w+%-%w+%-%w+%-%w+") then return val.Value end
    return nil
end

